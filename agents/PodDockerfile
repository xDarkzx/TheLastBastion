FROM python:3.10-slim

# Industrial Swarm Worker Image
WORKDIR /app

# Install system dependencies for Playwright/Nodriver
RUN apt-get update && apt-get install -y \
    wget \
    gnupg \
    libnss3 \
    libatk-bridge2.0-0 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpangocairo-1.0-0 \
    libgtk-3-0 \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy core logic
COPY core/ ./core/
COPY agents/ ./agents/

# Set interpreter as target
ENTRYPOINT ["python", "core/interpreter.py"]
