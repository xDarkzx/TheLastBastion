# ============================================================
# Smart Contract Deployment — Polygon Amoy Testnet
# ============================================================
# Copy to .env: cp .env.example .env
#
# You need:
# 1. A wallet with testnet POL (get from https://faucet.polygon.technology)
# 2. A Polygonscan API key (free at https://polygonscan.com/apis)
# ============================================================

POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
PRIVATE_KEY=0xyour_deployer_private_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# These get populated after deployment
PROOF_REGISTRY_ADDRESS=
AGENT_REGISTRY_ADDRESS=
