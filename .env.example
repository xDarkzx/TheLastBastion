# ============================================================
# The Last Bastion — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# MINIMUM SETUP: You only need a free Groq API key to run everything.
# Get one at: https://console.groq.com (free tier is plenty)
# ============================================================

# ── LLM Configuration ──────────────────────────────────────
# Groq provides the strategist brain (70B model, free tier)
GROQ_API_KEY=gsk_your_groq_api_key_here
STRATEGIST_MODEL=llama-3.3-70b-versatile

# Local LLM (optional — Groq handles everything if you skip this)
# Install Ollama from https://ollama.com and pull a model:
#   ollama pull qwen2.5:7b-instruct
LLM_PROVIDER=ollama
LLM_URL=http://localhost:11434/api/generate
LLM_MODEL=qwen2.5:7b-instruct

# ── Database ────────────────────────────────────────────────
# Default matches docker-compose.yml — change if using external DB
DATABASE_URL=postgresql://industrial_admin:swarm_secret_2026@127.0.0.1:5432/registry_base_vault
POSTGRES_PASSWORD=swarm_secret_2026

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Blockchain (optional) ──────────────────────────────────
# Everything works without these. Proofs record locally in the
# Merkle-chain ledger. Add these to also anchor on Polygon.
# BLOCKCHAIN_RPC_URL=https://rpc-amoy.polygon.technology
# BLOCKCHAIN_PRIVATE_KEY=0xyour_private_key_here
# PROOF_REGISTRY_ADDRESS=0x110affBAC98FCC6b86Da499550B1fC0aCA22e946
# AGENT_REGISTRY_ADDRESS=0xc9177baBF86FF16794AABd1a2169f898986a0D7D

# ── Polygon Deployment (only needed for deploying contracts) ─
# POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
# PRIVATE_KEY=0xyour_deployer_private_key
# POLYGONSCAN_API_KEY=your_polygonscan_api_key

# ── Remote Agent Host (optional) ───────────────────────────
# If running A2A agents on a separate machine (e.g. Raspberry Pi)
# BASTION_HOST=192.168.x.x
